# Caddy reads the DOMAIN value from its environment (set in docker-compose.yml,
# which in turn pulls it from your .env file). Caddy automatically obtains and
# renews a free Let's Encrypt HTTPS certificate for this domain.
{$DOMAIN} {
    encode zstd gzip
    reverse_proxy web:8000
}

# www → bare-domain redirect (Caddy fetches a second certificate for www
# automatically — requires the DNS A record for www to exist)
www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}
