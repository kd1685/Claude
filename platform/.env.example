# ─── Ascent Terminal — server settings ────────────────────────────────────────
# Copy to .env and fill in. Env vars load at container/server START —
# after editing on the VPS run:  docker compose up -d --force-recreate

DOMAIN=ascentterminal.com            # Caddy fetches the HTTPS cert for this

# ─── Access keys ──────────────────────────────────────────────────────────────
# Leave EMPTY in production (kills DEMO-KEY). Real keys live in keys.json
# via key_gen.py or the billing webhooks below. Env keys = architect tier.
ACCESS_KEYS=

# ─── TradingView webhook (inbound alert protection) ──────────────────────────
# Long random string (openssl rand -hex 32). Must match the "secret" field
# inside each TradingView alert's JSON message. Empty = receiver unprotected.
TV_WEBHOOK_SECRET=

# ─── Execution bridge (outbound order protection) ──────────────────────────
# Shared secret for outbound execution requests (HMAC-SHA256 header).
# Execution bridge checks this; keep it long and random.
EXECUTION_SECRET=

# ─── Exchange API keys (optional — only needed if YOU run execution) ─────────
# Keys below are for the ’server-side’ default exchange account.
# Users can supply their own via the UI — stored encrypted in keys.json.
BINANCE_API_KEY=
BINANCE_SECRET=
MEXC_API_KEY=
MEXC_SECRET=
BYBIT_API_KEY=
BYBIT_SECRET=

# ─── AI providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme

# ─── Stripe (subscription billing) ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Map Stripe price IDs to Ascent tiers
STRIPE_PRICE_SCOUT=
STRIPE_PRICE_OPERATOR=
STRIPE_PRICE_ARCHITECT=

# ─── SMTP (transactional e-mail) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ascentterminal.com
