# ─── Ascent Terminal — server settings ────────────────────────────────────────
# Copy to .env and fill in. Env vars load at container/server START —
# after editing on the VPS run:  docker compose up -d --force-recreate

DOMAIN=ascentterminal.com            # Caddy fetches the HTTPS cert for this

# ─── Access keys ──────────────────────────────────────────────────────────────────────────────────
# Leave EMPTY in production (kills DEMO-KEY). Real keys live in keys.json
# via key_gen.py or the billing webhooks below. Env keys = architect tier.
ACCESS_KEYS=

# ─── TradingView webhook (inbound alert protection) ──────────────────────────────────────────
# Long random string (openssl rand -hex 32). Must match the "secret" field
# inside each TradingView alert's JSON message. Empty = receiver unprotected.
TV_WEBHOOK_SECRET=

# ─── Execution bridge (outbound order protection) ───────────────────────────────────────────────
# EXECUTE_KEY arms the bridge + bots. Empty = nothing can EVER place an order.
# You also paste this same string into the UI when executing (X-Execute-Key).
EXECUTE_KEY=
EXEC_LIVE=false                      # master switch — paper-only until true
EXEC_MAX_USD=0                    # SERVER-WIDE ceiling on any order (abuse guard).
                                     # 0 = no ceiling. Each user sets their OWN
                                     # per-order cap in the app (Execute panel).
AUTO_EXECUTE=false                   # auto-act on incoming TV BUY/SELL alerts
EXEC_QUOTE_AMOUNT=50                 # order size for auto mode (USDT)
EXEC_EXCHANGE=                       # auto/bot default exchange (blank = EXCHANGE)
EXEC_API_KEY=                        # exchange API creds for auto/bot mode —
EXEC_API_SECRET=                     #   your own machine/server only; never
EXEC_API_PASSWORD=                   #   required for per-request UI execution

# ─── Data / misc ─────────────────────────────────────────────────────────────────────────────────
EXCHANGE=binance                     # default signal exchange (ccxt id)
DISCORD_WEBHOOK_URL=                 # optional — trend-flip posts to Discord
ASCENT_DB=                           # optional sqlite path (default data/ascent.db)
ASCENT_KEYS=                         # optional keys.json path

# ─── Claude AI analyst ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                   # console.anthropic.com — enables the AI tab
CLAUDE_MODEL=claude-sonnet-4-5
AI_MIN_TIER=observer                 # lowest tier allowed to use the AI tab
# Daily quota of FRESH analyses per key (cache hits are free):
AI_QUOTA_OBSERVER=10
AI_QUOTA_OPERATOR=30
AI_QUOTA_ARCHITECT=100

# ─── Automated key delivery (billing webhooks) ───────────────────────────────────────────────────
# Whop: dashboard → Developer → Webhooks → https://<domain>/api/whop-webhook
#       Name your products so the title contains observer/operator/architect.
WHOP_WEBHOOK_SECRET=
# Stripe: Developers → Webhooks → https://<domain>/api/stripe-webhook
#   Events: checkout.session.completed, invoice.paid, customer.subscription.deleted
#   On each Payment Link add metadata:  tier = observer | operator | architect
STRIPE_WEBHOOK_SECRET=
BILLING_KEY_DAYS=33                  # key lifetime per payment (31 days + grace)

# ─── Email (REQUIRED for automated key delivery — any SMTP provider) ─────────────────────────────
# Resend / Mailgun / Postmark / even a Gmail app password all work.
# Webhooks refuse to issue keys until this is set, so no buyer can pay
# without their key being deliverable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=support@ascentterminal.com

# ─── Liquidation feed ────────────────────────────────────────────────────────────────────────────
LIQ_FEED=true                        # Binance perp force-order stream (needs
                                     # websocket-client; false = off)

# ─── Personal-data encryption (set BEFORE taking real customers) ─────────────────────────────────
# Encrypts every stored customer email (mailing list, billing references).
# Generate once and keep with your other secrets:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Changing/losing this key makes previously stored addresses unreadable.
DATA_KEY=

# ─── Vanity links (ascentterminal.com/patreon etc. — optional overrides) ─────
# Clean brand-domain redirects for social posts. Defaults point at the
# AscentTerminal handles; set SOCIAL_DISCORD to your server invite to
# activate /discord (it 404s until set).
SOCIAL_PATREON=
SOCIAL_WHOP=
SOCIAL_X=
SOCIAL_DISCORD=
