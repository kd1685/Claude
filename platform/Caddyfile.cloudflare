# Use this Caddyfile variant when your domain is proxied through Cloudflare
# (orange-cloud enabled). Caddy cannot obtain a cert via HTTP-01 challenge
# while Cloudflare’s proxy is active, so we use the Cloudflare DNS-01 plugin.
#
# Prerequisites:
#   1. Build (or pull) a Caddy image that includes the Cloudflare DNS provider:
#      xcaddy build --with github.com/caddy-dns/cloudflare
#      — OR use the pre-built image in the Dockerfile.cf variant.
#   2. Set CF_API_TOKEN in your .env (Cloudflare → My Profile → API Tokens,
#      Zone:DNS:Edit permission for your domain).
#
# To activate: replace the Caddyfile mount in docker-compose.yml with
#   - ./Caddyfile.cloudflare:/etc/caddy/Caddyfile
# and add CF_API_TOKEN to .env.

ascentterminal.com {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }
    reverse_proxy app:8000
}
