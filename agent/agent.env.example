# Kingdom 1685 PC agent settings. Copy this file to  agent.env  and edit.

# Your live site (the VPS).
SERVER_URL=https://kd1685.com

# Must EXACTLY match AGENT_TOKEN set on the server. Keep it secret.
AGENT_TOKEN=PASTE_THE_SAME_LONG_RANDOM_TOKEN_HERE

# LDPlayer's ADB address (first instance is usually 127.0.0.1:5555).
ADB_SERIAL=127.0.0.1:5555
ADB_CONNECT=127.0.0.1:5555

# Path to adb.exe if it's not on your PATH (LDPlayer ships one, or use scrcpy's).
# ADB_PATH=C:\LDPlayer\LDPlayer9\adb.exe

# Calibration profile to match your emulator resolution.
#   720p  -> app/profiles/rok_720p.json   (LDPlayer default-ish)
#   1080p -> app/profiles/rok_1080p.json
UI_PROFILE=app/profiles/rok_720p.json

# Path to the tesseract OCR program (install the Windows build first).
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# How often to check the server for work, in seconds.
POLL_INTERVAL=2
