{
  "name": "rok_720p",
  "_comment": [
    "Calibrated for LDPlayer at 1280x720 LANDSCAPE. Rankings path: profile",
    "portrait (top-left) -> Rankings -> Individual Power/Kills. Dead-troop",
    "ranking does not exist in this menu, so only power + killpoints scan.",
    "Title/rank/locate anchors below are first-guesses — calibrate before use."
  ],
  "screen": {"width": 1280, "height": 720},

  "anchors": {
    "profile_avatar":  [40, 35],
    "rankings_button": [372, 600],
    "tab_power":       [310, 410],
    "tab_killpoints":  [640, 410],
    "tab_dead":        [310, 410],
    "close_x":         [1115, 43],
    "profile_close":   [1163, 71],
    "more_info_button":[192, 600],
    "more_info_close": [1113, 44],
    "profile_view_close": [1163, 71],
    "alliance_war":    [1180, 430],

    "search_button":   [48, 470],
    "search_field":    [640, 120],
    "first_result":    [640, 220],

    "city_center":     [640, 360],
    "city_title_icon": [560, 300],
    "title_justice":   [470, 430],
    "title_duke":      [580, 430],
    "title_architect": [690, 430],
    "title_scientist": [800, 430],

    "alliance_button": [1180, 360],
    "alliance_members":[180, 200],
    "member_search":   [640, 150],
    "first_member":    [400, 250],
    "member_manage":   [900, 250],
    "rank_r1":         [500, 300],
    "rank_r2":         [500, 360],
    "rank_r3":         [500, 420],
    "rank_r4":         [500, 480],
    "rank_r5":         [500, 540]
  },

  "macros": {
    "locate_player": [
      {"tap": "search_button"}, {"wait": 800},
      {"tap": "search_field"}, {"wait": 400},
      {"text": "{name}"}, {"key": 66}, {"wait": 1500},
      {"tap": "first_result"}, {"wait": 2500},
      {"ocr": {"region": [1000, 12, 240, 34], "into": "coords",
               "pattern": "(\\d+)\\s*[,Xx: ]+\\s*(\\d+)",
               "groups": {"x": 1, "y": 2}}}
    ],
    "give_title": [
      {"tap": "city_center"}, {"wait": 1200},
      {"tap": "city_title_icon"}, {"wait": 1000},
      {"tap_var": "title_point"}, {"wait": 800},
      {"back": true}, {"wait": 400}, {"back": true}
    ],
    "change_rank": [
      {"tap": "alliance_button"}, {"wait": 1200},
      {"tap": "alliance_members"}, {"wait": 1000},
      {"tap": "member_search"}, {"text": "{name}"}, {"key": 66}, {"wait": 1500},
      {"tap": "first_member"}, {"wait": 1000},
      {"tap": "member_manage"}, {"wait": 800},
      {"tap_var": "rank_point"}, {"wait": 800},
      {"back": true}, {"wait": 400}, {"back": true}
    ],
    "open_rankings": [
      {"tap": "profile_avatar"}, {"wait": 1800},
      {"tap": "rankings_button"}, {"wait": 1800},
      {"tap_var": "tab_point"}, {"wait": 1800}
    ],
    "close_rankings": [
      {"tap": "close_x"}, {"wait": 800},
      {"tap": "close_x"}, {"wait": 800},
      {"tap": "profile_close"}, {"wait": 800}
    ],
    "open_more_info": [
      {"tap": "more_info_button"}, {"wait": 1000}
    ],
    "open_war_reports": [
      {"tap": "alliance_button"}, {"wait": 1200},
      {"tap": "alliance_war"}, {"wait": 1500}
    ]
  },

  "rankings": {
    "_comment": "LDPlayer 720p Individual Power/Kills list: 6 visible rows, name + value regions.",
    "scroll": [640, 600, 640, 280, 600],
    "rows": [
      {"name": [285, 206, 440, 34], "value": [890, 206, 220, 34]},
      {"name": [285, 287, 440, 34], "value": [890, 287, 220, 34]},
      {"name": [285, 367, 440, 34], "value": [890, 367, 220, 34]},
      {"name": [285, 448, 440, 34], "value": [890, 448, 220, 34]},
      {"name": [285, 528, 440, 34], "value": [890, 528, 220, 34]},
      {"name": [285, 609, 440, 34], "value": [890, 609, 220, 34]}
    ]
  },

  "profiles": {
    "_comment": [
      "Deep scan, top-to-bottom. Each row has: name, value (POWER — big clean",
      "digits, used to de-dup a row across overlapping scrolls so we never skip",
      "or double-scan), tap (where to open the profile), and rank (kept for",
      "reference only). 'scroll' is slow to avoid fling overshoot. Stats read by",
      "LABEL on the More Info screen. Calibrated from a clean 1280x720 frame."
    ],
    "rows": [
      {"rank": [148, 208, 72, 44], "name": [285, 212, 380, 36], "value": [840, 212, 230, 36], "tap": [500, 230]},
      {"rank": [148, 286, 72, 44], "name": [285, 290, 380, 36], "value": [840, 290, 230, 36], "tap": [500, 308]},
      {"rank": [148, 365, 72, 44], "name": [285, 369, 380, 36], "value": [840, 369, 230, 36], "tap": [500, 387]},
      {"rank": [148, 443, 72, 44], "name": [285, 447, 380, 36], "value": [840, 447, 230, 36], "tap": [500, 465]},
      {"rank": [148, 521, 72, 44], "name": [285, 525, 380, 36], "value": [840, 525, 230, 36], "tap": [500, 543]},
      {"rank": [148, 600, 72, 44], "name": [285, 604, 380, 36], "value": [840, 604, 230, 36], "tap": [500, 622]}
    ],
    "scroll": [640, 540, 640, 250, 1100],
    "name_region": [285, 105, 300, 40],
    "profile_name_region": [464, 168, 220, 42],
    "_profile_name_help": "The governor NAME on the PROFILE screen: large bold white text just below the 'Governor (ID: ...)' line, with no alliance tag. Cleanest name source. Calibrated from a 1280x720 profile frame (TheBodyguard).",
    "id_region": [465, 148, 215, 28],
    "_id_region_help": "Governor ID on the PROFILE screen: the 'Governor (ID: NNNNNNNN)' line just above the name. Box spans the whole label; parse_int pulls the digits. Calibrated from a clean 1280x720 profile frame (ID 58509816).",
    "title_region": [360, 40, 560, 55],
    "labels": {
      "power":        "Power",
      "kill_points":  "Kill Points",
      "deads":        "Dead",
      "rss_gathered": "Resources Gathered",
      "rss_assist":   "Resource Assistance",
      "helps":        "Alliance Help"
    }
  },

  "map_scan": {
    "_comment": [
      "Find one governor by panning the map and watching for their nameplate.",
      "PLACEHOLDERS — calibrate: 'pan' is the swipe to move the view one step;",
      "'passes' is how many steps to try; 'coords_region' is where the X/Y shows",
      "after tapping a city. Optionally add a 'recenter' macro to jump to a known",
      "spot (via the coordinate search) before scanning."
    ],
    "passes": 24,
    "pan": [1000, 400, 280, 400, 500],
    "coords_region": [520, 30, 240, 34]
  },

  "war_reports": {
    "_comment": [
      "Alliance rally/war reports. PLACEHOLDER regions — calibrate with a screenshot",
      "of Alliance -> War -> reports list. One row per rally (leader + target + result)."
    ],
    "scroll": [640, 600, 640, 280, 600],
    "rows": [
      {"leader": [200, 200, 360, 40], "target": [600, 200, 360, 40], "status": [980, 200, 160, 40]},
      {"leader": [200, 280, 360, 40], "target": [600, 280, 360, 40], "status": [980, 280, 160, 40]},
      {"leader": [200, 360, 360, 40], "target": [600, 360, 360, 40], "status": [980, 360, 160, 40]},
      {"leader": [200, 440, 360, 40], "target": [600, 440, 360, 40], "status": [980, 440, 160, 40]},
      {"leader": [200, 520, 360, 40], "target": [600, 520, 360, 40], "status": [980, 520, 160, 40]}
    ]
  }
}
