# Reverse proxy for the Kingdom 1685 site.
# SITE_ADDRESS controls the public address:
#   * a domain (e.g. rok.example.com)  -> Caddy auto-provisions HTTPS
#   * unset                            -> serves plain HTTP on :80
# Set it in deploy/.env  (SITE_ADDRESS=rok.example.com)

{$SITE_ADDRESS::80} {
	encode gzip
	reverse_proxy app:8000
}
