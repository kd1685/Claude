# ---- Rise of Kingdoms 1685 tracker / controller config ----
# Copy to .env and edit. All values have safe defaults.

# Web/API server
HOST=0.0.0.0
PORT=8000

# SQLite database location
DB_PATH=data/rok1685.db

# Kingdom this instance tracks (used in the website header)
KINGDOM_ID=1685

# ---- Account control backend ----
# mock = no device, simulated actions (default; safe for first boot)
# adb  = drive a real RoK client on an Android device/emulator over ADB
CONTROL_BACKEND=mock

# Path to the adb binary (leave as 'adb' if it is on PATH)
ADB_PATH=adb

# Device/emulator to control.
# - Local emulator:        emulator-5554   (run `adb devices` to list)
# - Networked (redroid):   127.0.0.1:5555  (we run `adb connect` first)
ADB_SERIAL=127.0.0.1:5555

# If set, the worker runs `adb connect ADB_CONNECT` on startup (redroid/remote).
ADB_CONNECT=127.0.0.1:5555

# UI calibration profile (tap coordinates / OCR regions for your resolution)
UI_PROFILE=app/profiles/rok_720p.json

# Path to the tesseract OCR binary (only for adb backend rankings scanner)
TESSERACT_CMD=tesseract

# How often the control worker drains the command queue (seconds)
WORKER_INTERVAL=3
