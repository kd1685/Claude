# ---- Rise of Kingdoms 1685 tracker / controller config ----
# Copy to .env and edit. All values have safe defaults.

# Web/API server
HOST=0.0.0.0
PORT=8000

# SQLite database location
DB_PATH=data/rok1685.db

# Kingdom this instance tracks (used in the website header)
KINGDOM_ID=1685

# ---- Account control backend ----
# mock   = no device, simulated actions (default; safe for first boot)
# adb    = drive a RoK client on a local Android device/emulator over ADB
# remote = a PC agent (LDPlayer on your computer) drives the game and reports back
CONTROL_BACKEND=mock

# Shared secret for the PC agent (only when CONTROL_BACKEND=remote). Make it long
# and random, and put the SAME value in the agent's agent.env on your PC.
AGENT_TOKEN=

# Path to the adb binary (leave as 'adb' if it is on PATH)
ADB_PATH=adb

# Device/emulator to control.
# - Local emulator:        emulator-5554   (run `adb devices` to list)
# - Networked (redroid):   127.0.0.1:5555  (we run `adb connect` first)
ADB_SERIAL=127.0.0.1:5555

# If set, the worker runs `adb connect ADB_CONNECT` on startup (redroid/remote).
ADB_CONNECT=127.0.0.1:5555

# UI calibration profile (tap coordinates / OCR regions for your resolution).
# Available: app/profiles/rok_720p.json (1280x720), app/profiles/rok_1080p.json (1920x1080)
UI_PROFILE=app/profiles/rok_720p.json

# Path to the tesseract OCR binary (only for adb backend rankings scanner)
TESSERACT_CMD=tesseract

# How often the control worker drains the command queue (seconds)
WORKER_INTERVAL=3

# ---- Control-page auth (data pages are public; Control needs an account) ----
# Each officer gets their own account. These create the FIRST admin account on
# first run only; afterwards manage officers from the Control page (admin login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme1685
# Stable secret so logins survive restarts (any long random string).
# Leave blank to use a random per-process key (sessions reset on restart).
CONTROL_SECRET=
# Set true when served over HTTPS (e.g. behind the Caddy proxy with a domain).
COOKIE_SECURE=false
# SameSite for the session cookie. Use "none" (with COOKIE_SECURE=true) only if
# the website is on a different origin than this backend (e.g. GitHub Pages).
COOKIE_SAMESITE=lax

# ---- CORS: let a separately-hosted website call this API ----
# Comma-separated allowed origins. e.g. https://kd1685.github.io
# Leave empty when the website is served by this same backend.
CORS_ORIGINS=

# ---- Public hosting (used by deploy/docker-compose.yml + Caddy) ----
# A domain pointed at this VPS -> automatic HTTPS. Leave unset for plain :80.
# SITE_ADDRESS=rok.example.com
